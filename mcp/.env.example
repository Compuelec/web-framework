# Base URL of the framework REST API (no trailing slash).
# Example: http://localhost/web-framework/api  or  http://localhost:8080/api
FW_API_BASE_URL=http://localhost:8080/api

# API key configured in api/config.php (field `api.key`).
# The framework validates it with hash_equals against the Authorization header.
FW_API_KEY=replace-me

# Tables blocked for MCP tools (comma-separated). Empty = use safe defaults.
# Defaults: admins,activity_logs,sessions,tokens
# FW_DENY_TABLES=admins,activity_logs,sessions,tokens

# HTTP request timeout in milliseconds (default 15000).
# FW_HTTP_TIMEOUT_MS=15000

# === Authentication (two modes) ============================================
#
# Mode A: env credentials — the MCP server logs in automatically at startup.
# Required for unattended use (Claude Desktop, scripts).
# FW_AUTH_EMAIL=admin@your-domain.test
# FW_AUTH_PASSWORD=your-password
# FW_AUTH_TABLE=admins
# FW_AUTH_SUFFIX=admin
#
# Mode B: interactive — call the `mcp_login` tool, the server opens a CMS
# window where the admin authorizes the use of their current session JWT.
# No credentials are stored. This is the default when FW_AUTH_EMAIL/PASSWORD
# are unset.

# Hostname the framework uses to reach the local MCP callback during
# `mcp_login`. Default 127.0.0.1 works when both run on the same host.
# When the framework runs inside Docker Desktop, use `host.docker.internal`.
# FW_CALLBACK_HOST=127.0.0.1
