{
  "name": "@compuelec/web-framework-mcp",
  "version": "0.1.0",
  "description": "MCP server for Compuelec web-framework — exposes the REST API and CMS tables as MCP tools for LLM clients.",
  "type": "module",
  "bin": {
    "web-framework-mcp": "dist/index.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist",
    "README.md",
    ".env.example"
  ],
  "scripts": {
