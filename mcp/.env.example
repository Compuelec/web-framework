# URL base de la API REST del framework (sin trailing slash).
# Ej.: http://localhost/web-framework/api
FW_API_BASE_URL=http://localhost/web-framework/api

# API key configurada en api/config.php (campo `api.key`).
# El framework la valida con hash_equals contra el header Authorization.
FW_API_KEY=replace-me

# Tablas bloqueadas para tools del MCP (coma-separadas). Vacío = usar defaults seguros.
# Defaults: admins,activity_logs,sessions,tokens
# FW_DENY_TABLES=admins,activity_logs,sessions,tokens

# Timeout por request HTTP en ms (default 15000).
# FW_HTTP_TIMEOUT_MS=15000
